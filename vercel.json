{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "renderer/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/firebase.js",
      "dest": "/firebase.js"
    },
    {
      "src": "/renderer/(.*)",
      "dest": "/renderer/$1"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}